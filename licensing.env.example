# Activar enforcement solo en producción cuando ya tengas licencia emitida.
LICENSING_REQUIRE_VALID_LICENSE=true

# Debe coincidir con el productCode usado al emitir el token.
LICENSING_PRODUCT_CODE=scsql

# Identificador opcional para atar la licencia a una instalación concreta.
LICENSING_INSTANCE_ID=cliente-sa-prod-01

# Token emitido por el vendedor con qa/generate-license-token.sh
LICENSING_CURRENT_LICENSE_KEY=REEMPLAZAR_CON_TOKEN_FIRMADO

# Clave pública RSA en PEM. Mantener saltos de línea reales si la cargas como archivo.
LICENSING_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----
REEMPLAZAR_CON_TU_CLAVE_PUBLICA
-----END PUBLIC KEY-----"