SCSQL_ASPNETCORE_ENVIRONMENT=Production
SCSQL_TZ=America/Argentina/Buenos_Aires
SCSQL_INTERNAL_DB_CONNECTION=server=mysql-internal;port=3306;database=scsql;user=scsql;password=scsqlpass

SCSQL_JWT_ISSUER=scsql-api
SCSQL_JWT_AUDIENCE=scsql-admin
SCSQL_JWT_KEY=reemplazar-con-una-clave-larga-y-aleatoria

SCSQL_ADMIN_USERNAME=admin
SCSQL_ADMIN_PASSWORD=reemplazar-credencial-admin

SCSQL_STORAGE_ROOT_PATH=/app/storage
SCSQL_STORAGE_SQL_PATH=/app/storage/sql

SCSQL_SCHEDULER_POLL_SECONDS=5
SCSQL_SCHEDULER_CATCH_UP_WINDOW_DAYS=7
SCSQL_SCHEDULER_TIME_ZONE_ID=America/Argentina/Buenos_Aires

SCSQL_CONNECTION_ENCRYPTION_KEY=reemplazar-clave-de-cifrado-de-conexiones

SCSQL_LICENSING_REQUIRE_VALID_LICENSE=true
SCSQL_LICENSING_PRODUCT_CODE=novent
SCSQL_LICENSING_INSTANCE_ID=cliente-sa-prod-01
SCSQL_LICENSING_CURRENT_LICENSE_KEY=reemplazar-con-token-firmado
SCSQL_LICENSING_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\nREEMPLAZAR_CON_CLAVE_PUBLICA\n-----END PUBLIC KEY-----

SCSQL_VITE_API_BASE_URL=http://localhost:2008/api